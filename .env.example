# Publicas: podem ir para o bundle do navegador.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://rancho-seven.vercel.app

# Opcional. Nao habilite demo em producao para usuarios reais.
NEXT_PUBLIC_ENABLE_DEMO=false

# Secretas/server-only: configurar somente na Vercel/Supabase/ambiente servidor.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEFAULT_FAZENDA_ID=

WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Publicas do sandbox Twilio: nao colocar tokens aqui.
NEXT_PUBLIC_WHATSAPP_ENV=sandbox
NEXT_PUBLIC_TWILIO_SANDBOX_NUMBER=+14155238886
NEXT_PUBLIC_TWILIO_SANDBOX_JOIN_CODE=
