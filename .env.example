OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_TIMEOUT_MS=25000
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Rancho
BOT_PROCESSING_NOTICE_DELAY_MS=2700

# Publicas do sandbox Twilio: nao colocar tokens aqui.
