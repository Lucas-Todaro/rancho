# Publicas: podem ir para o bundle do navegador.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://rancho-seven.vercel.app

# Opcional. Nao habilite demo em producao para usuarios reais.
NEXT_PUBLIC_ENABLE_DEMO=false

# Secretas/server-only: configurar somente na Vercel/Supabase/ambiente servidor.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DEFAULT_FAZENDA_ID=

WHATSAPP_VERIFY_TOKEN=
META_WHATSAPP_TOKEN=
META_PHONE_NUMBER_ID=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

BOT_INTERPRETER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=
BOT_ALLOW_LEGACY_ROLLBACK=false
BOT_AI_PROVIDER=
BOT_AI_MODEL=
